# Copy this file to `.streamlit/secrets.toml` (gitignored) and fill in a Google
# service-account JSON to enable the persistent Community + Leaderboard features.
# On Streamlit Community Cloud, paste the same block into App → Settings → Secrets.
#
# Setup:
#   1. Create a Google Cloud service account, enable the Google Sheets + Drive APIs,
#      and download its JSON key.
#   2. Create a Google Sheet with a worksheet named `reports` whose first row is:
#      id  timestamp  block_key  lat  lon  borough  action_type  trees_count  detail  place  display_name  status  session_hash
#   3. Share the Sheet with the service account's client_email as an Editor.
#   4. Fill the values below from the JSON key and the Sheet URL.
#
# Without this file the app still runs — Community reports stay session-only and the
# leaderboard shows reference blocks (graceful degradation).

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/<YOUR_SHEET_ID>/edit"
worksheet = "reports"
type = "service_account"
project_id = ""
private_key_id = ""
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = ""
client_id = ""
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = ""

# Optional: a free Socrata app token raises NYC Open Data rate limits (not required).
# SOCRATA_APP_TOKEN = ""
